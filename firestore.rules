rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MIX AURA SECURITY POLICY
     *
     * Core Philosophy:
     * This ruleset implements a dual-access model designed for a professional portfolio and service showcase.
     * 1. Public Content: Services and Projects are globally readable to maximize visibility but restricted
     *    to administrative users for all modifications.
     * 2. Secure Inquiries: Contact form submissions are publicly creatable to allow prospective clients 
     *    to reach out, but the data is immediately siloed and only accessible by administrators.
     *
     * Data Structure:
     * - /services/{serviceId}: Publicly viewable service offerings.
     * - /projects/{projectId}: Publicly viewable portfolio case studies.
     * - /contactSubmissions/{submissionId}: Private user inquiries.
     * - /roles_admin/{adminId}: A lookup collection where the presence of a UID grants administrative rights.
     *
     * Key Security Decisions:
     * - Authorization Independence: User permissions are verified by checking the /roles_admin collection,
     *   ensuring that access logic is not coupled to complex document hierarchies.
     * - Prototyping Flexibility: While authorization is strictly enforced based on roles, the schema 
     *   validation is limited to relational integrity (ID consistency) to allow for rapid UI/UX iteration.
     * - Protection of Admin Roles: Only existing administrators can modify the administrative user list.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Verifies if the authenticated user is an administrator.
     * Checks for the existence of the user's UID in the roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Helper for destructive or state-changing operations on existing documents. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    /** Ensures that the ID in the document data matches the path ID. */
    function isRelationalValid(id) {
      return request.resource.data.id == id;
    }

    /** Ensures a field is not changed during an update. */
    function isImmutable(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the Service collection. Services are public for marketing but managed by admins.
     * @path /services/{serviceId}
     * @allow (get, list) All users, even unauthenticated.
     * @allow (create, update, delete) Only authenticated users found in the roles_admin collection.
     * @deny (write) Any user not in the roles_admin collection.
     * @principle Public Read with Admin-Only Writes.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create: if isAdmin() && isRelationalValid(serviceId);
      allow update: if isExistingAdmin() && isImmutable('id');
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for the Project collection. Portfolio projects are public for showcase.
     * @path /projects/{projectId}
     * @allow (get, list) All users, even unauthenticated.
     * @allow (create, update, delete) Only authenticated users found in the roles_admin collection.
     * @deny (write) Users without the admin role.
     * @principle Public Read with Admin-Only Writes.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isAdmin() && isRelationalValid(projectId);
      allow update: if isExistingAdmin() && isImmutable('id');
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Contact Submissions. Allows anyone to submit inquiries, but only admins to read or manage them.
     * @path /contactSubmissions/{submissionId}
     * @allow (create) Any user (including anonymous/public) to submit a contact form.
     * @allow (get, list, update, delete) Restricted to administrators.
     * @deny (get, list) Any non-admin user trying to read inquiries.
     * @principle Public Create with Restricted Admin Access.
     */
    match /contactSubmissions/{submissionId} {
      allow create: if isRelationalValid(submissionId);
      allow get, list: if isAdmin();
      allow update: if isExistingAdmin() && isImmutable('id');
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for the Administrative Roles lookup collection.
     * @path /roles_admin/{adminId}
     * @allow (get, list, create, update, delete) Restricted to existing administrators.
     * @deny (read, write) Any user who is not already an administrator.
     * @principle Role-Based Access Control (RBAC) Management.
     */
    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && isRelationalValid(adminId);
      allow update: if isExistingAdmin() && isImmutable('id');
      allow delete: if isExistingAdmin();
    }
  }
}