rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MIX AURA SECURITY ARCHITECTURE
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a "Public Portfolio / Admin Management" model. The application acts 
     * primarily as a high-end cinematic display for agency services and projects. Consequently, 
     * most content is globally readable to facilitate search engine indexing and anonymous 
     * browsing, while all write operations and sensitive data (like contact leads) are 
     * strictly guarded by an administrative role check.
     *
     * DATA STRUCTURE:
     * - /services/{serviceId}: Publicly readable agency services.
     * - /projects/{projectId}: Publicly readable portfolio case studies.
     * - /website_settings/global: Publicly readable site configuration.
     * - /contact_submissions/{id}: Publicly writable (for lead gen), Admin-only readable.
     * - /roles_admin/{uid}: Role-based access control (RBAC) lookup table.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Admin status is determined via a dedicated collection 
     *    (/roles_admin). This allows any rule to verify permissions using a single exists() 
     *    call without navigating complex document hierarchies.
     * 2. Anonymous Lead Generation: The 'contact_submissions' collection allows any user 
     *    (including unauthenticated ones) to create a document, but strictly forbids 
     *    anyone except administrators from reading or listing the results.
     * 3. Relational Integrity: In this prototyping phase, we enforce that the internal 
     *    'id' field of documents matches their Firestore document ID to ensure data 
     *    consistency for client-side routing.
     */

    // --- Global Helper Functions ---

    /** Checks if the requester is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the requester's UID exists in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Verifies administrative rights and ensures the document exists for state-changing operations. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    /** Validates relational integrity: internal 'id' must match the path ID on creation. */
    function isValidCreation(id) {
      return request.resource.data.id == id;
    }

    /** Validates relational integrity: internal 'id' must remain immutable on update. */
    function isValidUpdate() {
      return request.resource.data.id == resource.data.id;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for agency services. Publicly visible, admin managed.
     * @path /services/{serviceId}
     * @allow (get, list) if true (public access)
     * @deny (create, update, delete) if user is not an admin
     * @principle Public consumption with restricted content management.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidCreation(serviceId);
      allow update: if isExistingAdmin() && isValidUpdate();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for portfolio projects. Publicly visible, admin managed.
     * @path /projects/{projectId}
     * @allow (get, list) if true (public access)
     * @deny (create) if id in data doesn't match projectId path
     * @principle Structural segregation and public read access.
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidCreation(projectId);
      allow update: if isExistingAdmin() && isValidUpdate();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for lead generation submissions.
     * @path /contact_submissions/{submissionId}
     * @allow (create) if true (allow leads from any visitor)
     * @allow (get, list, update, delete) if user is admin
     * @principle Secure intake of private user data with restricted administrative review.
     */
    match /contact_submissions/{submissionId} {
      allow create: if isValidCreation(submissionId);
      allow get, list: if isAdmin();
      allow update: if isExistingAdmin() && isValidUpdate();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for global site settings. Single document 'global'.
     * @path /website_settings/global
     * @allow (get) if true (public config)
     * @deny (list) if true (prevents collection scanning)
     * @principle Single-record configuration with public visibility.
     */
    match /website_settings/{settingId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidCreation(settingId);
      allow update: if isExistingAdmin() && isValidUpdate();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Rules for the admin role lookup table.
     * @path /roles_admin/{adminUid}
     * @allow (get, list, create, update, delete) if user is an existing admin.
     * @deny (all) if user is not already authorized as an admin.
     * @principle Authorization Independence via a dedicated RBAC collection.
     */
    match /roles_admin/{adminUid} {
      // Note: Initial admin setup usually occurs via Firebase Console or Admin SDK.
      allow get, list: if isAdmin();
      allow create: if isAdmin() && isValidCreation(adminUid);
      allow update: if isExistingAdmin() && isValidUpdate();
      allow delete: if isExistingAdmin();
    }
  }
}

/** 
 * PROTOTYPING MODE ACTIVE:
 * These rules enforce strict authorization (who can access) but allow flexible data shapes 
 * (what the data looks like). Only relational fields (like 'id') are validated for integrity.
 */